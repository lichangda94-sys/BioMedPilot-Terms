{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lichangda94-sys/BioMedPilot-Terms/schemas/term_entry.schema.json",
  "title": "BioMedPilot Term Entry",
  "description": "Public candidate and example schema for Chinese-English biomedical term entries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "zh",
    "en",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3
    },
    "category": {
      "type": "string",
      "enum": [
        "disease",
        "tissue",
        "biomarker",
        "method",
        "organism",
        "intervention",
        "outcome",
        "database",
        "general"
      ]
    },
    "zh": {
      "type": "string",
      "minLength": 1
    },
    "en": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "example",
        "candidate",
        "review_required"
      ]
    },
    "abbreviations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "synonyms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "database_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "mesh_terms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "emtree_terms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "string"
    },
    "source_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
